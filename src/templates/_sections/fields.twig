{% import '_includes/forms' as forms %}

<h1>Fields</h1>

{{ forms.field({
  instructions: "Choose which fields are forbidden from being accessed through queries and mutations – per schema. Fields are shown as they appear in GraphQL queries. Any attempts to access a restricted field will cause the request to throw.",
  first: true,
}, '') }}

<hr style='border-color:transparent' />

{% if schemaFields is empty %}
  <div class="warning">
    <p>Please configure your GraphQL schemas in the Users tab first. Field restrictions are configured per schema.</p>
  </div>
{% else %}
  {% for schemaName, fields in schemaFields %}
    {% if fields is not empty %}
      <h2>{{ schemaName }} Schema Fields</h2>
      
      <div class="tablepane">
        <table class='data fullwidth'>
          <thead>
            <tr>
              <th>GraphQL Field Name</th>
              <th>Type</th>
              <th>Access Level</th>
            </tr>
          </thead>

          <tbody>
            {% for fieldName, fieldInfo in fields %}
              <tr>
                <td style='vertical-align:top;padding-top:20px'>
                  {{ forms.field({
                    label: fieldName,
                    instructions: fieldInfo.description ? fieldInfo.description : 'From: ' ~ fieldInfo.type,
                  }, '') }}
                </td>
                
                <td style='vertical-align:top;padding-top:20px'>
                  <code>{{ fieldInfo.type }}</code>
                </td>

                <td style='vertical-align:top;padding-top:20px'>
                  {% set schemaKey = 'schema-' ~ schemaName %}
                  {{ forms.selectField({
                    name: 'fieldRestrictions[' ~ schemaKey ~ '][' ~ fieldName ~ ']',
                    value: settings.fieldRestrictions[schemaKey][fieldName] ?? 'queryMutate',
                    options: [
                      { value: 'queryMutate', label: 'Query & Mutate' },
                      { value: 'query', label: 'Query Only' },
                      { value: 'private', label: 'Private' },
                    ],
                  }) }}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      
      {% if not loop.last %}
        <hr style='margin: 2rem 0;' />
      {% endif %}
    {% endif %}
  {% endfor %}
{% endif %}
